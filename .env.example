# ─────────────────────────────────────────────────────────────
#  Awais Portfolio — VPS environment variables
#
#  Served behind the shared central Caddy via the `proxy` network.
#  WEB_CONTAINER_NAME must match the upstream in deploy/awaisdesigner.caddy.
#
#  Manual deploy:
#    cd $DEPLOY_PATH && cp .env.example .env && docker compose up -d --build
#
#  CI deploy: GitHub Actions secrets (see deploy/DEPLOY.md).
# ─────────────────────────────────────────────────────────────

WEB_PORT=274
IMAGE_NAME=awais-portfolio/web:latest
WEB_CONTAINER_NAME=awais-portfolio-web
