# ─────────────────────────────────────────────────────────────
#  Awais Portfolio — VPS environment variables (web container only)
#
#  HTTPS is handled by the shared Caddy on your VPS (see deploy/Caddyfile.snippet).
#
#  Manual deploy:
#    ssh deploy@YOUR_VPS
#    cd $DEPLOY_PATH
#    cp .env.example .env && nano .env
#    docker compose up -d --build
#
#  CI deploy: store these as GitHub Actions secrets (see deploy/DEPLOY.md).
# ─────────────────────────────────────────────────────────────

WEB_PORT=274
IMAGE_NAME=awais-portfolio/web:latest
WEB_CONTAINER_NAME=awais-portfolio-web

# Shared Docker network — must match your existing site's compose network.
DOCKER_NETWORK=syedtech-net
